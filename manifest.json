{
  "manifest_version": 3,
  "name": "Live Transcribe & AI Answer",
  "version": "2.0.0",
  "description": "Real-time system audio transcription with AI-powered question answering",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "tabCapture"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Live Transcribe",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
